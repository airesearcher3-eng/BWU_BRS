# ══════════════════════════════════════════════════════════════
#  BWU BRS — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Secrets / environment ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
secrets/

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/
MANIFEST

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/
backend/.venv/
ml_service/.venv/

# ── Alembic ────────────────────────────────────────────────────
# Keep versions/ tracked; ignore local env overrides
backend/alembic.ini.local

# ── Node / Frontend ────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/
package-lock.json

# ── Sensitive bank data (NEVER commit) ────────────────────────
# Bank statements, ledgers, and BRS workbooks must stay outside
# the repo or under an explicitly gitignored path.
*.xlsx
*.xls
*.csv
!tests/fixtures/**/*.xlsx
!tests/fixtures/**/*.xls
!tests/fixtures/**/*.csv

# ── Databases ──────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ── Runtime data ───────────────────────────────────────────────
uploads/
output/
logs/
*.log
*.log.*
gunicorn_error.log

# ── Docker ─────────────────────────────────────────────────────
docker-compose.override.yml
.docker/

# ── IDE / editor ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ── OS ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Jupyter ────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temporary / misc ───────────────────────────────────────────
*.tmp
*.bak
*.orig
*.rej
.cache/
tmp/
temp/
