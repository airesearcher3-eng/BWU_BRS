# BRS Automation System — environment template.
# Copy to .env and fill in real values. Never commit .env.

# ── Environment ────────────────────────────────────────────────
# "production" | "development". Production triggers fail-fast checks
# on missing secrets and CORS origins.
ENV=production
DEBUG=false

# ── Secrets ────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── HTTP / Security ────────────────────────────────────────────
# Comma-separated. Wildcard '*' is rejected when ENV=production.
CORS_ORIGINS=https://brs.example.edu
# Comma-separated trusted Host headers. '*' disables the check.
ALLOWED_HOSTS=brs.example.edu

# Rate limits (format: "<count>/<unit>", unit in second|minute|hour|day)
DEFAULT_RATE_LIMIT=120/minute
LOGIN_RATE_LIMIT=5/minute

# Upload cap (bytes). Default 25 MB.
MAX_UPLOAD_BYTES=26214400

# Auth policy
PASSWORD_MIN_LENGTH=12

# ── Storage paths ──────────────────────────────────────────────
DATABASE_PATH=db/brs.db
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=output
LOG_DIR=logs
LOG_LEVEL=INFO

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=4
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=1000
FORWARDED_ALLOW_IPS=127.0.0.1

# ── Cleanup ────────────────────────────────────────────────────
UPLOAD_MAX_AGE_DAYS=60

# ── Google Gemini RAG ──────────────────────────────────────────
GOOGLE_API_KEY=
RAG_LLM_MODEL=gemini-2.5-flash
